# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Generated data — downloaded by fetch_cots.py, regenerated by build scripts
data/raw/cots/
data/processed/*.csv
data/processed/*.json

# Reports — generated by analyze.py
# Raw per-song/per-section CSVs are gitignored (large, regenerable from scripts)
reports/*.csv
# But the human-readable summary markdown IS committed
!reports/*.md
*.html
!notebooks/**/*.html

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
